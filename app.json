      "./plugins/with-widget-target-version",
      "expo-background-task",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "OneValue",
              "label": "1:1 Tracker",
              "description": "One main tracker at a glance",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetCellWidth": 1,
              "targetCellHeight": 1,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "TwoValues",
              "label": "2:2 Trackers",
              "description": "Two main trackers together",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "RingValues",
              "label": "2:3 Hearts + Stats",
              "description": "Hearts plus three tracker stats",
              "minWidth": "180dp",
              "minHeight": "250dp",
              "targetCellWidth": 2,
              "targetCellHeight": 3,
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-font",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
